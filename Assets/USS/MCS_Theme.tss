/* 
 * MCS_Theme.tss — assign THIS as the Theme Style Sheet in Panel Settings.
 * It imports Unity's base theme first, then forces our color overrides on top.
 */
@import url("unity-theme://Default");

/* Nuclear override — beats the imported theme */
* {
    -unity-font-definition: initial;
}

Label, .unity-label {
    color: rgb(255, 255, 255);
    -unity-text-align: upper-left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
